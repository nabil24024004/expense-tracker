<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude SQLite database files containing private financial entries from cloud backup -->
    <exclude domain="database" path="expense_database"/>
    <exclude domain="database" path="expense_database-wal"/>
    <exclude domain="database" path="expense_database-shm"/>
    <!-- Include settings and preferences -->
    <include domain="sharedpref" path="."/>
</full-backup-content>
