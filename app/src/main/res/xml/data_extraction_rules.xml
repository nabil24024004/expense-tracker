<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Room database files from cloud backup for privacy -->
        <exclude domain="database" path="expense_database"/>
        <exclude domain="database" path="expense_database-wal"/>
        <exclude domain="database" path="expense_database-shm"/>
        <include domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <!-- Allow Room database files for direct device-to-device transfer during migration -->
        <include domain="database" path="expense_database"/>
        <include domain="database" path="expense_database-wal"/>
        <include domain="database" path="expense_database-shm"/>
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
